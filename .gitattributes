# See https://git-scm.com/docs/gitattributes for more about git attribute files.
# Auto-normalize line endings for text files
* text=auto eol=lf
# Database schema (generated by Rails)
db/schema.rb linguist-generated=true
db/*.sqlite3 linguist-vendor=true
# Rails credentials (encrypted)
config/credentials*.yml.enc diff=rails_credentials
# Vendored files
vendor/* linguist-vendored=true
# Node/Electron files
desktop/node_modules/* linguist-vendor=true
desktop/*.log export-ignore=true
# Yarn/pnpm lockfiles (use LF)
yarn.lock text eol=lf
pnpm-lock.yaml text eol=lf
package-lock.json text eol=lf
# Shell scripts (LF only)
*.sh text eol=lf
bin/* text eol=lf
# Windows batch files (CRLF)
*.bat text eol=crlf
*.cmd text eol=crlf
# Images and binaries (don't diff)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.sqlite3 binary
# Ignore large generated files
*.log export-ignore=true
tmp/* export-ignore=true
log/* export-ignore=true
storage/* export-ignore=true
# Rails temp files
.cache/* export-ignore=true
*.exe filter=lfs diff=lfs merge=lfs -text
*.nupkg filter=lfs diff=lfs merge=lfs -text
*.zip filter=lfs diff=lfs merge=lfs -text
*.dll filter=lfs diff=lfs merge=lfs -text
*.pak filter=lfs diff=lfs merge=lfs -text
*.asar filter=lfs diff=lfs merge=lfs -text
