# See https://docs.github.com/en/get-started/git-basics/ignoring-files for more about ignoring files.

# ── Dependencies ──────────────────────────────────────────
/.bundle
/node_modules
/desktop/node_modules
/vendor/bundle

# ── Ruby / Rails ──────────────────────────────────────────
db/*.sqlite3
db/*.sqlite3-journal
db/*.sqlite3-*
/log/*
/tmp/*
/storage/*
!/log/.keep
!/tmp/.keep
!/storage/.keep
/tmp/storage/*
/public/assets
/public/packs
/public/packs-test
/public/system

# ── Rails credentials ─────────────────────────────────────
/config/master.key
/config/credentials.yml.enc
/config/*.key

# ── Environment variables ─────────────────────────────────
.env*
!.env.example

# ── Runtime data ──────────────────────────────────────────
pids
*.pid
*.seed
*.seeds
*.pid.lock

# ── Testing ───────────────────────────────────────────────
coverage/
capybara-*.html
/.rspec

# ── Linters / Formatters ──────────────────────────────────
.rubocop-todo.yml
.reek
.flamegraph.svg

# ── OS generated files ────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ── IDE / Editor ──────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~

# ── Electron — unpacked build output ─────────────────────
# The raw unpacked folder contains hundreds of loose .dll /
# .pak / .exe files. Committing them to LFS wastes quota fast.
# Only the compressed make/ outputs (installer + zip) are kept.
desktop/out/Frieren Anime Archive-win32-x64/

# ── Electron — Squirrel auto-generated metadata ───────────
# RELEASES is regenerated on every build — not useful in VCS.
desktop/out/make/squirrel.windows/RELEASES

# ── Electron — other build artifacts ─────────────────────
desktop/dist/
desktop/*.blockmap
desktop/latest-*.yml
desktop/.webpack/
desktop/.electron-cache/

# ── Yarn / NPM ────────────────────────────────────────────
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
desktop/package-lock.json

# ── Misc ──────────────────────────────────────────────────
*.rbc
*.rdb
*.html

# ── Electron — bundled Ruby runtime ───────────────────────
# Binary, installed at build time — not source-controlled.
desktop/ruby-runtime/
desktop/rails-api-dist/

# ── Electron — Rails API copy ─────────────────────────────
# Sourced from the repo root at build time, not duplicated.
desktop/rails-api/

# ── Electron — vendored gems ──────────────────────────────
# Installed at build time via bundle install.
desktop/vendor/
vendor/bundle/

# ── Bundler config ────────────────────────────────────────
# Set locally per machine — never commit.
.bundle/
desktop/.bundle/