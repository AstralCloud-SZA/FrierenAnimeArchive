# See https://docs.github.com/en/get-started/git-basics/ignoring-files for more about ignoring files.

# dependencies
/.bundle
/node_modules
/desktop/node_modules
/vendor/bundle

# Ruby / Rails
db/*.sqlite3
db/*.sqlite3-journal
db/*.sqlite3-*
/log/*
/tmp/*
/storage/*
!/log/.keep
!/tmp/.keep
!/storage/.keep
/tmp/storage/*
/public/assets
/public/packs
/public/packs-test
/public/system

# Rails credentials
/config/master.key
/config/credentials.yml.enc
/config/*.key

# Environment variables
.env*
!.env.example

# Runtime data
pids
*.pid
*.seed
*.seeds
*.pid.lock

# Testing
coverage/
capybara-*.html
/.rspec

# Linters / Formatters
.rubocop-todo.yml
.reek
.flamegraph.svg

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# IDE / Editor
.idea/
.vscode/
*.swp
*.swo
*~

# Electron build output (Forge)
desktop/out/
desktop/dist/
desktop/*.blockmap
desktop/latest-*.yml
desktop/.webpack/
desktop/.electron-cache/

# Yarn/NPM
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
desktop/package-lock.json

# Misc
*.rbc
capybara-*.html
*.rdb
*.html

# Electron — bundled Ruby runtime (binary, not source-controlled)
desktop/ruby-runtime/
desktop/rails-api-dist/

# Electron — Rails API copy (sourced from repo root, not duplicated)
desktop/rails-api/

# Electron — vendored gems (installed at build time)
desktop/vendor/
vendor/bundle/

# Bundler config (set locally per machine)
.bundle/
desktop/.bundle/